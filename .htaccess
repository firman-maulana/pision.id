RewriteEngine On

# Force HTTPS (optional, uncomment if needed)
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Prevent direct access to .html files (redirect to clean URL)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)\.html [NC]
RewriteRule ^ %1 [R=301,L]

# Main page mappings
RewriteRule ^tes$ ai-software-about.html [L]
RewriteRule ^affiliate-policy$ ai-software-affiliate-policy.html [L]
RewriteRule ^affiliates$ ai-software-affiliates.html [L]
RewriteRule ^analytics$ ai-software-analytics.html [L]
RewriteRule ^blog$ ai-software-blog.html [L]
RewriteRule ^detail-blog$ ai-software-blog-details.html [L]
RewriteRule ^blog-inline$ ai-software-blog-inline.html [L]
RewriteRule ^brandkit$ ai-software-brandkit.html [L]
RewriteRule ^career$ ai-software-career.html [L]
RewriteRule ^career-details$ ai-software-career-details.html [L]
RewriteRule ^case-study$ ai-software-case-study.html [L]
RewriteRule ^case-study-details$ ai-software-case-study-details.html [L]
RewriteRule ^changelog$ ai-software-changelog.html [L]
RewriteRule ^contact$ ai-software-contact.html [L]
RewriteRule ^portofolio$ ai-software-customer.html [L]
RewriteRule ^detail-portofolio$ ai-software-customer-details.html [L]
RewriteRule ^documentation$ ai-software-documentation.html [L]
RewriteRule ^download$ ai-software-download.html [L]
RewriteRule ^faq$ ai-software-faq.html [L]
RewriteRule ^features$ ai-software-features.html [L]
RewriteRule ^gdpr$ ai-software-gdpr.html [L]
RewriteRule ^glossary$ ai-software-glossary.html [L]
RewriteRule ^integration$ ai-software-integration.html [L]
RewriteRule ^legal$ ai-software-legal.html [L]
RewriteRule ^login$ ai-software-login.html [L]
RewriteRule ^our-manifesto$ ai-software-our-manifesto.html [L]
RewriteRule ^press$ ai-software-press.html [L]
RewriteRule ^product$ ai-software-pricing.html [L]
RewriteRule ^privacy-policy$ ai-software-privacy-policy.html [L]
RewriteRule ^process$ ai-software-process.html [L]
RewriteRule ^referral-program$ ai-software-referral-program.html [L]
RewriteRule ^refund-policy$ ai-software-refund-policy.html [L]
RewriteRule ^about$ ai-software-security.html [L]
RewriteRule ^service-details$ ai-software-service-details.html [L]
RewriteRule ^services$ ai-software-services.html [L]
RewriteRule ^signup$ ai-software-signup.html [L]
RewriteRule ^success-stories$ ai-software-success-stories.html [L]
RewriteRule ^support$ ai-software-support.html [L]
RewriteRule ^team$ ai-software-team.html [L]
RewriteRule ^team-details$ ai-software-team-details.html [L]
RewriteRule ^terms-conditions$ ai-software-terms-conditions.html [L]
RewriteRule ^testimonial$ ai-software-testimonial.html [L]
RewriteRule ^tutorial$ ai-software-tutorial.html [L]
RewriteRule ^use-case$ ai-software-use-case.html [L]
RewriteRule ^whitepaper$ ai-software-whitepaper.html [L]
RewriteRule ^whitepaper-details$ ai-software-whitepaper-details.html [L]
RewriteRule ^why-choose-us$ ai-software-why-choose-us.html [L]

# 404 error pages
RewriteRule ^404-2$ 404-2.html [L]
RewriteRule ^404-3$ 404-3.html [L]
